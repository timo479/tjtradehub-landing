# ============================================================
# TJ TradeHub – Environment Variables
# Kopiere diese Datei als .env.local und fülle alle Werte aus
# ============================================================

# NextAuth
# Generieren mit: openssl rand -base64 32
NEXTAUTH_URL=https://deine-domain.com
NEXTAUTH_SECRET=

# Supabase (supabase.com/dashboard → Project Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Stripe (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook Secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Product Catalog → dein Produkt → Price ID
STRIPE_PRICE_ID=price_...

# MetaAPI (metaapi.cloud → Account → API Access Token)
# Ein Token für alle Kunden – Kunden geben nur ihr MT4/MT5 Login ein
METAAPI_TOKEN=your-metaapi-token-here
# MT4/MT5 Password Encryption Key – generieren mit: openssl rand -hex 32
# PFLICHT: Ohne diesen Key werden Passwörter NICHT verschlüsselt
METAAPI_ENCRYPTION_KEY=

# Resend (resend.com → API Keys)
RESEND_API_KEY=re_...

# Cron Secret (für GitHub Actions Undeploy-Cron)
# generieren mit: openssl rand -base64 32
CRON_SECRET=

# Trial-Dauer in Tagen (Standard: 7)
TRIAL_DAYS=7

# TikTok Pixel ID (aus TikTok Ads Manager)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=D70P9FBC77UDENRHHFKG

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL (ohne trailing slash)
NEXT_PUBLIC_APP_URL=https://deine-domain.com
