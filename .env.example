# ============================================================
# TJ TradeHub – Environment Variables
# Kopiere diese Datei als .env.local und fülle alle Werte aus
# ============================================================

# NextAuth
# Generieren mit: openssl rand -base64 32
NEXTAUTH_URL=https://deine-domain.com
NEXTAUTH_SECRET=

# Supabase (supabase.com/dashboard → Project Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Stripe (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook Secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Product Catalog → dein Produkt → Price ID
STRIPE_PRICE_ID=price_...

# App URL (ohne trailing slash)
NEXT_PUBLIC_APP_URL=https://deine-domain.com
